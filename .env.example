# ──────────────────────────────────────────────
# Relay.gg — Environment Variables
# Copy this file to .env and fill in values.
# Never commit .env to version control.
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=relay
POSTGRES_PASSWORD=relay_dev_password
POSTGRES_DB=relay

# Redis
REDIS_URL=redis://localhost:6379

# NATS JetStream
NATS_URL=nats://localhost:4222

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=relay_minio_access
MINIO_SECRET_KEY=relay_minio_secret
MINIO_BUCKET=relay
MINIO_USE_SSL=false

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=relay_meili_master_key

# JWT
JWT_SECRET=change_me_in_production_min_32_chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# OAuth (optional — leave blank to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Livekit (voice & video)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=relay_livekit_key
LIVEKIT_API_SECRET=relay_livekit_secret

# Coturn (TURN/STUN)
COTURN_REALM=relay.gg
COTURN_SECRET=relay_coturn_secret

# Federation
SERVER_DOMAIN=localhost
FEDERATION_ENABLED=false
FEDERATION_PRIVATE_KEY_PATH=./secrets/ed25519.pem

# Service ports
AUTH_PORT=8080
API_PORT=8081
MESSAGING_PORT=8082
NOTIFICATION_PORT=8083
SEARCH_PORT=8084
FILE_PORT=8085
INTEGRATION_PORT=8086
MEDIA_PORT=8087
FEDERATION_PORT=8088
