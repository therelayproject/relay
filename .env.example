# Relay — example environment variables
# Copy to .env and fill in values for local development.
# Never commit .env to version control.

# ── Common ────────────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=debug
LOG_PRETTY=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://relay:relay_dev@localhost:5432/relay?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── NATS ──────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=relay_minio
S3_SECRET_KEY=relay_minio_secret
S3_BUCKET_FILES=relay-files
S3_BUCKET_AVATARS=relay-avatars

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
